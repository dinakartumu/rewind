    {
      "name": "attended_events",
      "purpose": "One row per live event the user has tickets for (sports/music/arts). Base fact table for attending. Type-specific data lives in event_data JSON.",
      "columns": [
        { "name": "id", "type": "integer", "note": "PK" },
        { "name": "category", "type": "text", "note": "sports | music | arts" },
