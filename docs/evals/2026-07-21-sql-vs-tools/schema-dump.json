          "name": "collection_id",
          "type": "integer",
          "note": "→ discogs_collection.id"
        },
        {
          "name": "release_id",
          "type": "integer",
          "note": "→ discogs_releases.id"
        },
        {
          "name": "lastfm_album_name",
          "type": "text",
