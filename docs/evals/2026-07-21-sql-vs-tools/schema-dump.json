        { "name": "genres", "type": "text", "note": "JSON array" },
        { "name": "rating", "type": "integer", "note": "0-5" },
        { "name": "date_added", "type": "text", "note": "ISO 8601" }
      ]
    },
    {
      "name": "discogs_collection_stats",
