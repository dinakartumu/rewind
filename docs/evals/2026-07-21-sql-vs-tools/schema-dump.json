    },
    {
      "name": "discogs_collection",
      "purpose": "The owned records — one row per physical copy in the collection. Base fact table for the vinyl/CD collection.",
      "columns": [
        { "name": "id", "type": "integer", "note": "PK" },
        {
          "name": "release_id",
          "type": "integer",
          "note": "→ discogs_releases.id"
        },
        {
          "name": "instance_id",
          "type": "integer",
          "note": "unique per-copy id"
        },
        { "name": "folder_id", "type": "integer" },
        { "name": "rating", "type": "integer", "note": "0-5, 0 = unrated" },
