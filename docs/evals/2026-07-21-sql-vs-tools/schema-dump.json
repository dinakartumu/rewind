        { "name": "by_decade", "type": "text", "note": "JSON {decade:count}" }
      ]
    },
    {
      "name": "collection_listening_xref",
      "purpose": "Cross-references owned records (discogs_collection) with Last.fm play counts by matched name — how often the owner streams what they own.",
      "columns": [
        { "name": "id", "type": "integer", "note": "PK" },
