          "name": "event_type",
          "type": "text",
          "note": "e.g. mlb_game, concert, theater"
        },
        {
          "name": "event_date",
          "type": "text",
          "note": "YYYY-MM-DD (venue-local)"
        },
        {
          "name": "event_datetime",
          "type": "text",
          "note": "ISO 8601, nullable"
        },
        {
          "name": "venue_id",
          "type": "integer",
          "note": "→ venues.id, nullable"
        },
        { "name": "title", "type": "text" },
        { "name": "subtitle", "type": "text", "note": "nullable" },
